{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "external_directory": "deny"
  },
  "provider": {
    "local/ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local, via host.docker.internal)",
      "options": {
        "baseURL": "{env:OPENCODE_OLLAMA_BASE_URL}",
        "apiKey": "ollama"
      },
      "models": {
        "gemma4:31b": {},
        "nemotron-3-nano:30b": {},
        "qwen3-coder:30b": {},
        "qwen3-coder-fixed:30b": {},
        "qwen2.5-coder:7b": {}
      }
    }
  }
}
