# Credentials — extracted by scripts/extract-opencode-key.sh, host-local only
auth-data/

# Generated results — artifacts of a run, not source
results/*
!results/.gitkeep

# Terraform local state and caches — .terraform.lock.hcl IS committed
# (see docs/VERSIONING.md); everything else here is machine-local
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars
terraform/crash.log
terraform/*.plan
terraform/*-plan.log

# One-time patch-delivery scripts (apply-*.sh) and build logs -- these
# are session artifacts, not source; each is regenerated fresh per
# patch/build rather than reused, so tracking them just adds churn.
/apply-*.sh
/docker-build.log

# OS/editor cruft
.DS_Store
*.swp

# Python cache
__pycache__/
*.pyc
